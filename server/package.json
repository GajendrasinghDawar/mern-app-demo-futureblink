{
  "name": "server",
  "version": "1.0.0",
  "description": "Express API for OpenRouter and MongoDB",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch . --ext ts --exec node server.ts",
    "start": "node server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.10.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^24.7.2",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}