{
  "name": "server",
  "version": "1.0.0",
  "description": "Express API for OpenRouter and MongoDB",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec node src/server.ts",
    "start": "node src/server.ts",
    "typecheck": "tsc --noEmit",
    "check-db": "node check-db.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^9.3.3",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/node": "^24.7.2",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}